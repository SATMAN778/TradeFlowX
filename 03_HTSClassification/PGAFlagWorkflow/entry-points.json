            "description": "Goods description for additional PGA keyword matching"
          }
        },
        "required": ["htsCode"]
      },
      "output": {
        "type": "object",
        "properties": {
          "pgaFlag": {
            "type": "boolean"
          },
          "pgaAgencies": {
            "type": "string",
            "description": "JSON array of PGA agency objects requiring review"
          }
        }
      }
    }
  ]
}
