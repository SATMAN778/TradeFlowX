{
    "id": "case-TradeXCase0",
    "version": "23.0.0",
    "name": "TradeXCase",
    "description": "Manages the full cross-border import lifecycle — PO intake, ISF 10+2 filing, HTS classification, PGA screening, OFAC denied-party screening, CBP customs entry, and post-entry duty reconciliation.",
