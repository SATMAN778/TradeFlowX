            { "id": "supplierCountry", "var": "supplierCountry", "name": "supplierCountry", "type": "string", "default": "" },
            { "id": "goodsDescription", "var": "goodsDescription", "name": "goodsDescription", "type": "string", "default": "" },
            { "id": "quantity", "var": "quantity", "name": "quantity", "type": "integer", "default": "0" },
            { "id": "unitPriceUsd", "var": "unitPriceUsd", "name": "unitPriceUsd", "type": "float", "default": "0" },
            { "id": "totalValueUsd", "var": "totalValueUsd", "name": "totalValueUsd", "type": "float", "default": "0" },
            { "id": "incoterms", "var": "incoterms", "name": "incoterms", "type": "string", "default": "" },
            { "id": "expectedShipDate", "var": "expectedShipDate", "name": "expectedShipDate", "type": "date", "default": "" },
            { "id": "portOfLoading", "var": "portOfLoading", "name": "portOfLoading", "type": "string", "default": "" },
            { "id": "portOfEntry", "var": "portOfEntry", "name": "portOfEntry", "type": "string", "default": "" },
            { "id": "blNumber", "var": "blNumber", "name": "blNumber", "type": "string", "default": "" },
            { "id": "cooDeclaration", "var": "cooDeclaration", "name": "cooDeclaration", "type": "string", "default": "" },
            { "id": "cooVerified", "var": "cooVerified", "name": "cooVerified", "type": "boolean", "default": "false" },
            { "id": "transshipmentFlag", "var": "transshipmentFlag", "name": "transshipmentFlag", "type": "boolean", "default": "false" },
            { "id": "transshipmentRisk", "var": "transshipmentRisk", "name": "transshipmentRisk", "type": "string", "default": "LOW" },
            { "id": "poDataComplete", "var": "poDataComplete", "name": "poDataComplete", "type": "boolean", "default": "false" },
            { "id": "cooVerificationRequired", "var": "cooVerificationRequired", "name": "cooVerificationRequired", "type": "boolean", "default": "false" },
