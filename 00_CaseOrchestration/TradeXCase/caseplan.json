        "caseIdentifierType": "external",
        "caseAppEnabled": true,
        "publishVersion": 2,
        "caseUnifiedSchemaEnabled": true,
        "caseDirectlyPassTaskOutputs": true,
        "intsvcActivityConfig": "v2",
        "caseExitRules": [{
            "id": "Condition_CsExit1",
            "displayName": "Complete Rule 1",
            "marksCaseComplete": true,
            "rules": [[{ "id": "Rule_CsExit1", "rule": "required-stages-completed" }]]
        }]
    },
    "bindings": [],
    "variables": {
        "inputs": [],
        "outputs": [],
        "inputOutputs": [
            { "id": "triggerSource", "var": "triggerSource", "name": "triggerSource", "type": "string", "default": "MANUAL" },
            { "id": "emailSubject", "var": "emailSubject", "name": "emailSubject", "type": "string", "default": "" },
            { "id": "senderEmail", "var": "senderEmail", "name": "senderEmail", "type": "string", "default": "" },
            { "id": "sfRecordId", "var": "sfRecordId", "name": "sfRecordId", "type": "string", "default": "" },
