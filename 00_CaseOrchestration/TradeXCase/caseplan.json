            { "id": "isfDeadlineUtc", "var": "isfDeadlineUtc", "name": "isfDeadlineUtc", "type": "string", "default": "" },
            { "id": "isfDataComplete", "var": "isfDataComplete", "name": "isfDataComplete", "type": "boolean", "default": "false" },
            { "id": "isfAmendmentRequired", "var": "isfAmendmentRequired", "name": "isfAmendmentRequired", "type": "boolean", "default": "false" },
            { "id": "htsCode", "var": "htsCode", "name": "htsCode", "type": "string", "default": "" },
            { "id": "htsCandidates", "var": "htsCandidates", "name": "htsCandidates", "type": "jsonSchema", "default": "" },
            { "id": "htsConfidence", "var": "htsConfidence", "name": "htsConfidence", "type": "float", "default": "0" },
            { "id": "dutyRatePct", "var": "dutyRatePct", "name": "dutyRatePct", "type": "float", "default": "0" },
            { "id": "dutyAmountUsd", "var": "dutyAmountUsd", "name": "dutyAmountUsd", "type": "float", "default": "0" },
            { "id": "mpfAmount", "var": "mpfAmount", "name": "mpfAmount", "type": "float", "default": "0" },
            { "id": "hmfAmount", "var": "hmfAmount", "name": "hmfAmount", "type": "float", "default": "0" },
            { "id": "pgaFlag", "var": "pgaFlag", "name": "pgaFlag", "type": "boolean", "default": "false" },
            { "id": "pgaAgencies", "var": "pgaAgencies", "name": "pgaAgencies", "type": "jsonSchema", "default": "" },
            { "id": "pgaStatus", "var": "pgaStatus", "name": "pgaStatus", "type": "string", "default": "NOT_REQUIRED" },
            { "id": "partyNames", "var": "partyNames", "name": "partyNames", "type": "jsonSchema", "default": "" },
            { "id": "ofacScreeningResults", "var": "ofacScreeningResults", "name": "ofacScreeningResults", "type": "jsonSchema", "default": "" },
            { "id": "ofacMatchScore", "var": "ofacMatchScore", "name": "ofacMatchScore", "type": "float", "default": "0" },
            { "id": "ofacClearStatus", "var": "ofacClearStatus", "name": "ofacClearStatus", "type": "string", "default": "PENDING" },
            { "id": "entryNumber", "var": "entryNumber", "name": "entryNumber", "type": "string", "default": "" },
            { "id": "cbpStatus", "var": "cbpStatus", "name": "cbpStatus", "type": "string", "default": "PENDING" },
            { "id": "examType", "var": "examType", "name": "examType", "type": "string", "default": "" },
            { "id": "cf28Questions", "var": "cf28Questions", "name": "cf28Questions", "type": "jsonSchema", "default": "" },
            { "id": "cf29ActionType", "var": "cf29ActionType", "name": "cf29ActionType", "type": "string", "default": "" },
            { "id": "estimatedDutyUsd", "var": "estimatedDutyUsd", "name": "estimatedDutyUsd", "type": "float", "default": "0" },
            { "id": "actualDutyUsd", "var": "actualDutyUsd", "name": "actualDutyUsd", "type": "float", "default": "0" },
            { "id": "dutyVarianceUsd", "var": "dutyVarianceUsd", "name": "dutyVarianceUsd", "type": "float", "default": "0" },
            { "id": "dutyVariancePct", "var": "dutyVariancePct", "name": "dutyVariancePct", "type": "float", "default": "0" },
            { "id": "documentationComplete", "var": "documentationComplete", "name": "documentationComplete", "type": "boolean", "default": "false" },
            { "id": "archivalStatus", "var": "archivalStatus", "name": "archivalStatus", "type": "string", "default": "PENDING" },
            { "id": "landedCostPosted", "var": "landedCostPosted", "name": "landedCostPosted", "type": "boolean", "default": "false" },
            { "id": "dutySavingsOpportunity", "var": "dutySavingsOpportunity", "name": "dutySavingsOpportunity", "type": "string", "default": "NONE" },
            { "id": "estimatedSavingsUsd", "var": "estimatedSavingsUsd", "name": "estimatedSavingsUsd", "type": "float", "default": "0" },
            { "id": "caseState", "var": "caseState", "name": "caseState", "type": "string", "default": "ACTIVE" }
        ]
    },
    "nodes": [
        {
            "id": "trig-Manual001",
            "type": "case-management:Trigger",
            "data": {
                "label": "Manual Start",
                "description": "Manual trigger for creating a TradeX case instance",
                "parentElement": { "id": "root", "type": "case-management:root" },
                "uipath": { "serviceType": "None" }
            }
        },
        {
            "id": "Stage_Ordr01",
            "type": "case-management:Stage",
            "data": {
                "label": "Trade Order Intake",
                "description": "Initiates on email or Salesforce trigger. Fetches and validates PO fields, saves documents to UiPath Storage, runs COO transshipment risk classification.",
                "isRequired": true,
                "parentElement": { "id": "root", "type": "case-management:root" },
                "isInvalidDropTarget": false,
                "isPendingParent": false,
                "tasks": [
                    [{ "id": "tS1L0PoDat", "elementId": "Stage_Ordr01-tS1L0PoDat", "displayName": "PO Data Fetch", "isRequired": true, "shouldRunOnlyOnce": true, "type": "api-workflow", "data": {} }],
                    [{ "id": "tS1L1EmDoc", "elementId": "Stage_Ordr01-tS1L1EmDoc", "displayName": "Email Document Collector", "isRequired": false, "shouldRunOnlyOnce": true, "type": "agent", "data": {} }],
                    [{ "id": "tS1L2CooAg", "elementId": "Stage_Ordr01-tS1L2CooAg", "displayName": "COO Classification Agent", "isRequired": true, "shouldRunOnlyOnce": true, "type": "agent", "data": {} }],
                    [{ "id": "tS1L3HT001", "elementId": "Stage_Ordr01-tS1L3HT001", "displayName": "HT-01 Missing PO Fields", "isRequired": false, "shouldRunOnlyOnce": false, "type": "action", "data": {} }],
                    [{ "id": "tS1L4HT002", "elementId": "Stage_Ordr01-tS1L4HT002", "displayName": "HT-02 COO Verification", "isRequired": false, "shouldRunOnlyOnce": false, "type": "action", "data": {} }]
                ],
                "entryConditions": [{ "id": "cOrdr01Entr1", "displayName": "Entry Rule 1", "rules": [[{ "id": "rOrdr01Rule1", "rule": "case-entered" }]] }]
            }
        },
        {
            "id": "Stage_ISFf01",
            "type": "case-management:Stage",
            "data": {
                "label": "ISF 10+2 Filing",
                "description": "Prepares, submits, and monitors the ISF 10+2 filing to CBP ACE. Handles missing elements, Do Not Load, and material amendments.",
                "isRequired": true,
                "parentElement": { "id": "root", "type": "case-management:root" },
                "isInvalidDropTarget": false,
                "isPendingParent": false,
                "tasks": [
                    [{ "id": "tS2L0IsfCl", "elementId": "Stage_ISFf01-tS2L0IsfCl", "displayName": "ISF Data Collector Agent", "isRequired": true, "shouldRunOnlyOnce": true, "type": "agent", "data": {} }],
                    [{ "id": "tS2L1AceIs", "elementId": "Stage_ISFf01-tS2L1AceIs", "displayName": "ACE ISF Filing Workflow", "isRequired": true, "shouldRunOnlyOnce": true, "type": "api-workflow", "data": {} }],
                    [{ "id": "tS2L2AcePl", "elementId": "Stage_ISFf01-tS2L2AcePl", "displayName": "ACE ISF Status Poller", "isRequired": true, "shouldRunOnlyOnce": false, "type": "rpa", "data": {} }],
                    [{ "id": "tS2L3HT003", "elementId": "Stage_ISFf01-tS2L3HT003", "displayName": "HT-03 Missing ISF Elements", "isRequired": false, "shouldRunOnlyOnce": false, "type": "action", "data": {} }],
                    [{ "id": "tS2L4HT004", "elementId": "Stage_ISFf01-tS2L4HT004", "displayName": "HT-04 ISF Do Not Load", "isRequired": false, "shouldRunOnlyOnce": false, "type": "action", "data": {} }],
                    [{ "id": "tS2L5HT005", "elementId": "Stage_ISFf01-tS2L5HT005", "displayName": "HT-05 ISF Material Amendment", "isRequired": false, "shouldRunOnlyOnce": false, "type": "action", "data": {} }]
                ]
            }
        },
        {
            "id": "Stage_HTSc01",
            "type": "case-management:Stage",
            "data": {
                "label": "HTS Classification & Duty",
                "description": "IDP extraction, AI HTS classification (LangGraph), duty rate lookup, and PGA flag evaluation. Human review for confidence below 90%.",
                "isRequired": true,
                "parentElement": { "id": "root", "type": "case-management:root" },
                "isInvalidDropTarget": false,
                "isPendingParent": false,
                "tasks": [
                    [{
                        "id": "tS3L0IdpPp",
                        "elementId": "Stage_HTSc01-tS3L0IdpPp",
                        "displayName": "IDP Document Pipeline",
                        "isRequired": true,
                        "shouldRunOnlyOnce": true,
                        "type": "rpa",
                        "data": {
                            "inputs": [
                                { "name": "in_documentList", "type": "text", "id": "in_documentList", "var": "in_documentList", "value": "=vars.documentList", "elementId": "Stage_HTSc01-tS3L0IdpPp" },
                                { "name": "in_poNumber", "type": "text", "id": "in_poNumber", "var": "in_poNumber", "value": "=vars.poNumber", "elementId": "Stage_HTSc01-tS3L0IdpPp" }
                            ],
                            "outputs": [
                                { "name": "out_extractedFields", "type": "text", "id": "out_extractedFields", "var": "out_extractedFields", "value": "", "source": "", "target": "=vars.documentList", "elementId": "Stage_HTSc01-tS3L0IdpPp" },
                                { "name": "out_goodsDescription", "type": "text", "id": "out_goodsDescription", "var": "out_goodsDescription", "value": "", "source": "", "target": "=vars.goodsDescription", "elementId": "Stage_HTSc01-tS3L0IdpPp" }
                            ]
                        },
                        "entryConditions": [{
                            "id": "cIdpEntr1",
                            "displayName": "Entry Rule 1",
                            "rules": [[{ "id": "rIdpRule1", "rule": "current-stage-entered" }]]
                        }]
                    }],
                    [{
                        "id": "tS3L1HtsCl",
                        "elementId": "Stage_HTSc01-tS3L1HtsCl",
                        "displayName": "HTS Classification Agent",
                        "isRequired": true,
                        "shouldRunOnlyOnce": true,
                        "type": "agent",
                        "data": {
                            "inputs": [
                                { "name": "shipmentDocument", "type": "text", "id": "shipmentDocument", "var": "shipmentDocument", "value": "=vars.documentList", "elementId": "Stage_HTSc01-tS3L1HtsCl" },
                                { "name": "countryOfOrigin", "type": "text", "id": "countryOfOrigin", "var": "countryOfOrigin", "value": "=vars.supplierCountry", "elementId": "Stage_HTSc01-tS3L1HtsCl" }
                            ],
                            "outputs": [
                                { "name": "final_hts_code", "type": "text", "id": "final_hts_code", "var": "final_hts_code", "value": "", "source": "", "target": "=vars.htsCode", "elementId": "Stage_HTSc01-tS3L1HtsCl" },
                                { "name": "confidence", "type": "number", "id": "htsConfidence", "var": "htsConfidence", "value": "", "source": "", "target": "=vars.htsConfidence", "elementId": "Stage_HTSc01-tS3L1HtsCl" },
                                { "name": "candidates", "type": "text", "id": "candidates", "var": "candidates", "value": "", "source": "", "target": "=vars.htsCandidates", "elementId": "Stage_HTSc01-tS3L1HtsCl" }
                            ]
                        },
                        "entryConditions": [{
                            "id": "cHtsEntr1",
                            "displayName": "Entry Rule 1",
                            "rules": [[{ "id": "rHtsRule1", "rule": "selected-tasks-completed", "selectedTasksIds": ["tS3L0IdpPp"] }]]
                        }]
                    }],
                    [{
                        "id": "tS3L2DutyR",
                        "elementId": "Stage_HTSc01-tS3L2DutyR",
                        "displayName": "Duty Rate Lookup Workflow",
                        "isRequired": true,
                        "shouldRunOnlyOnce": true,
                        "type": "api-workflow",
                        "data": {
                            "inputs": [
                                { "name": "htsCode", "type": "text", "id": "htsCode", "var": "htsCode", "value": "=vars.htsCode", "elementId": "Stage_HTSc01-tS3L2DutyR" },
                                { "name": "totalValueUsd", "type": "number", "id": "totalValueUsd", "var": "totalValueUsd", "value": "=vars.totalValueUsd", "elementId": "Stage_HTSc01-tS3L2DutyR" },
                                { "name": "supplierCountry", "type": "text", "id": "supplierCountry", "var": "supplierCountry", "value": "=vars.supplierCountry", "elementId": "Stage_HTSc01-tS3L2DutyR" }
                            ],
                            "outputs": [
                                { "name": "dutyRatePct", "type": "number", "id": "dutyRatePct", "var": "dutyRatePct", "value": "", "source": "", "target": "=vars.dutyRatePct", "elementId": "Stage_HTSc01-tS3L2DutyR" },
                                { "name": "dutyAmountUsd", "type": "number", "id": "dutyAmountUsd", "var": "dutyAmountUsd", "value": "", "source": "", "target": "=vars.dutyAmountUsd", "elementId": "Stage_HTSc01-tS3L2DutyR" },
                                { "name": "mpfAmount", "type": "number", "id": "mpfAmount", "var": "mpfAmount", "value": "", "source": "", "target": "=vars.mpfAmount", "elementId": "Stage_HTSc01-tS3L2DutyR" },
                                { "name": "hmfAmount", "type": "number", "id": "hmfAmount", "var": "hmfAmount", "value": "", "source": "", "target": "=vars.hmfAmount", "elementId": "Stage_HTSc01-tS3L2DutyR" },
                                { "name": "dutyBreakdownJson", "type": "text", "id": "dutyBreakdownJson", "var": "dutyBreakdownJson", "value": "", "source": "", "target": "=vars.dutyBreakdownJson", "elementId": "Stage_HTSc01-tS3L2DutyR" }
                            ]
                        },
                        "entryConditions": [{
                            "id": "cDutyEntr1",
                            "displayName": "Entry Rule 1",
                            "rules": [[
                                { "id": "rDutyRule1", "rule": "selected-tasks-completed", "selectedTasksIds": ["tS3L1HtsCl"] },
                                { "id": "rDutyRule2", "rule": "adhoc", "conditionExpression": "=js:vars.htsConfidence >= 90" }
                            ]]
                        }]
                    }],
                    [{
                        "id": "tS3L3PgaFl",
                        "elementId": "Stage_HTSc01-tS3L3PgaFl",
                        "displayName": "PGA Flag Workflow",
                        "isRequired": true,
                        "shouldRunOnlyOnce": true,
                        "type": "api-workflow",
                        "data": {
                            "inputs": [
                                { "name": "htsCode", "type": "text", "id": "htsCode", "var": "htsCode", "value": "=vars.htsCode", "elementId": "Stage_HTSc01-tS3L3PgaFl" },
                                { "name": "goodsDescription", "type": "text", "id": "goodsDescription", "var": "goodsDescription", "value": "=vars.goodsDescription", "elementId": "Stage_HTSc01-tS3L3PgaFl" }
                            ],
                            "outputs": [
                                { "name": "pgaFlag", "type": "boolean", "id": "pgaFlag", "var": "pgaFlag", "value": "", "source": "", "target": "=vars.pgaFlag", "elementId": "Stage_HTSc01-tS3L3PgaFl" },
                                { "name": "pgaAgencies", "type": "text", "id": "pgaAgencies", "var": "pgaAgencies", "value": "", "source": "", "target": "=vars.pgaAgencies", "elementId": "Stage_HTSc01-tS3L3PgaFl" }
                            ]
                        },
                        "entryConditions": [{
                            "id": "cPgaEntr1",
                            "displayName": "Entry Rule 1",
                            "rules": [[
                                { "id": "rPgaRule1", "rule": "selected-tasks-completed", "selectedTasksIds": ["tS3L1HtsCl"] },
                                { "id": "rPgaRule2", "rule": "adhoc", "conditionExpression": "=js:vars.htsConfidence >= 90" }
                            ]]
                        }]
                    }],
                    [{
                        "id": "tS3L4HT006",
                        "elementId": "Stage_HTSc01-tS3L4HT006",
                        "displayName": "HT-06 HTS Review 70-90%",
                        "isRequired": false,
                        "shouldRunOnlyOnce": false,
                        "type": "action",
                        "data": {},
                        "entryConditions": [{
                            "id": "cHT06Entr1",
                            "displayName": "Entry Rule 1",
                            "rules": [[
                                { "id": "rHT06Rule1", "rule": "selected-tasks-completed", "selectedTasksIds": ["tS3L1HtsCl"] },
                                { "id": "rHT06Rule2", "rule": "adhoc", "conditionExpression": "=js:vars.htsConfidence >= 70 && vars.htsConfidence < 90" }
                            ]]
                        }]
                    }],
                    [{
                        "id": "tS3L5HT007",
                        "elementId": "Stage_HTSc01-tS3L5HT007",
                        "displayName": "HT-07 Manual HTS Classification",
                        "isRequired": false,
                        "shouldRunOnlyOnce": false,
                        "type": "action",
                        "data": {},
                        "entryConditions": [{
                            "id": "cHT07Entr1",
                            "displayName": "Entry Rule 1",
                            "rules": [[
                                { "id": "rHT07Rule1", "rule": "selected-tasks-completed", "selectedTasksIds": ["tS3L1HtsCl"] },
                                { "id": "rHT07Rule2", "rule": "adhoc", "conditionExpression": "=js:vars.htsConfidence < 70" }
                            ]]
                        }]
                    }],
                    [{
                        "id": "tS3L6HT008",
                        "elementId": "Stage_HTSc01-tS3L6HT008",
                        "displayName": "HT-08 PGA Documentation Required",
                        "isRequired": false,
                        "shouldRunOnlyOnce": false,
                        "type": "action",
                        "data": {},
                        "entryConditions": [{
                            "id": "cHT08Entr1",
                            "displayName": "Entry Rule 1",
                            "rules": [[
                                { "id": "rHT08Rule1", "rule": "selected-tasks-completed", "selectedTasksIds": ["tS3L3PgaFl"] },
                                { "id": "rHT08Rule2", "rule": "adhoc", "conditionExpression": "=js:vars.pgaFlag == true" }
                            ]]
                        }]
                    }]
                ]
            }
        },
        {
            "id": "Stage_PGAs01",
            "type": "case-management:Stage",
            "data": {
                "label": "PGA Screening",
                "description": "Conditional stage — runs only when pgaFlag=true. CrewAI PGA Coordinator manages agency submissions; RPA polls for approval/hold/refusal.",
                "isRequired": false,
                "parentElement": { "id": "root", "type": "case-management:root" },
                "isInvalidDropTarget": false,
                "isPendingParent": false,
                "tasks": [
                    [{ "id": "tS4L0PgaCo", "elementId": "Stage_PGAs01-tS4L0PgaCo", "displayName": "PGA Agency Coordinator", "isRequired": true, "shouldRunOnlyOnce": true, "type": "api-workflow", "data": {} }],
                    [{ "id": "tS4L1PgaPl", "elementId": "Stage_PGAs01-tS4L1PgaPl", "displayName": "PGA Status Polling Bot", "isRequired": true, "shouldRunOnlyOnce": false, "type": "rpa", "data": {} }],
                    [{ "id": "tS4L2HT009", "elementId": "Stage_PGAs01-tS4L2HT009", "displayName": "HT-09 PGA Hold", "isRequired": false, "shouldRunOnlyOnce": false, "type": "action", "data": {} }],
                    [{ "id": "tS4L3HT010", "elementId": "Stage_PGAs01-tS4L3HT010", "displayName": "HT-10 PGA Refusal", "isRequired": false, "shouldRunOnlyOnce": false, "type": "action", "data": {} }]
                ]
            }
        },
        {
            "id": "Stage_OFAC01",
            "type": "case-management:Stage",
            "data": {
                "label": "OFAC & Denied-Party Screening",
                "description": "Party extraction agent, LangGraph transshipment risk refinement, and OFAC SDN API screening of all parties. Human review for fuzzy matches and confirmed hits.",
                "isRequired": true,
                "parentElement": { "id": "root", "type": "case-management:root" },
                "isInvalidDropTarget": false,
                "isPendingParent": false,
